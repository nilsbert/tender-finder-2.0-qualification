# ============================================================
# Qualification Microservice — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# cp .env.example .env

# --- Execution Mode ---
EXECUTION_MODE=LOCAL

# --- Database ---
# SQLite (default for local development):
DATABASE_URL=sqlite+aiosqlite:///./qualification.db

# MSSQL (for Docker / Production):
# MSSQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:localhost,1433;Database=qualification;Uid=sa;Pwd={YourPassword};Encrypt=no;TrustServerCertificate=yes;

# --- Service Ports ---
PORT=8013

# --- Inter-Service URLs ---
# ENRICHING_URL=http://localhost:8002
# RATING_URL=http://localhost:8012
